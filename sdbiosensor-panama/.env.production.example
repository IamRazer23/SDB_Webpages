# ============================================================
# SD Biosensor Panamá — Plantilla de entorno de PRODUCCIÓN
# Copiar a .env en el servidor y rellenar con secretos reales
# (gestionados por Vault / Doppler / Secrets Manager, NO en git).
# ============================================================

APP_NAME="SD Biosensor Panamá"
APP_ENV=production
APP_DEBUG=false
APP_KEY=                                  # php artisan key:generate (único por entorno)
APP_TIMEZONE=America/Panama
APP_URL=https://www.sdbiosensor.com.pa

APP_LOCALE=es
APP_FALLBACK_LOCALE=es

# --- Logging -------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# --- Base de datos: Supabase PostgreSQL ----------------------
# Pooler en modo transacción (6543) para apps con muchas conexiones;
# 5432 (sesión) para migraciones/jobs largos.
DB_CONNECTION=pgsql
DB_HOST=aws-0-us-east-1.pooler.supabase.com
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=postgres.[PROJECT-REF]
DB_PASSWORD=                              # secreto
DB_SSLMODE=require

# --- Sesiones / cache (Redis para escalado horizontal) -------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_HOST=
REDIS_PASSWORD=
REDIS_PORT=6379

# --- Supabase (Storage / API / Auth) -------------------------
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=               # secreto: solo backend, nunca al cliente
FILESYSTEM_DISK=s3                        # Supabase Storage es compatible S3
AWS_ENDPOINT=https://[PROJECT-REF].storage.supabase.co/storage/v1/s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=media
AWS_USE_PATH_STYLE_ENDPOINT=true

# --- Sentry --------------------------------------------------
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=                          # inyectado por CI (git sha / tag)

# --- Correo --------------------------------------------------
MAIL_MAILER=smtp
MAIL_FROM_ADDRESS="panama@sdbiosensor.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
